#include <windows.h>
#include "AIAssistantResources.h"
#include "AIAssistantVersion.h"

IDD_AIASSISTANT_PANEL DIALOGEX 0, 0, 280, 315
STYLE DS_SETFONT | WS_POPUP | WS_CAPTION | WS_SYSMENU
EXSTYLE WS_EX_TOOLWINDOW | WS_EX_WINDOWEDGE
CAPTION "AI Assistant"
FONT 9, "Segoe UI", 400, 0, 0x0
BEGIN
    COMBOBOX        IDC_AI_PROVIDER_COMBO, 5, 7, 50, 100, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    COMBOBOX        IDC_AI_MODEL_COMBO, 58, 7, 100, 200, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    PUSHBUTTON      "Sign in", IDC_AI_COPILOT_SIGNIN_BUTTON, 132, 6, 30, 14
    PUSHBUTTON      "A+", IDC_AI_FONT_INCREASE_BUTTON, 166, 6, 18, 14
    PUSHBUTTON      "A-", IDC_AI_FONT_DECREASE_BUTTON, 186, 6, 18, 14
    PUSHBUTTON      "Settings", IDC_AI_SETTINGS_BUTTON, 208, 6, 35, 14
    PUSHBUTTON      "Clear", IDC_AI_CLEAR_BUTTON, 246, 6, 28, 14

    CONTROL         "", IDC_AI_CHAT_HISTORY, "RichEdit20W", ES_MULTILINE | ES_READONLY | ES_AUTOVSCROLL | WS_VSCROLL | WS_BORDER | WS_TABSTOP, 5, 26, 270, 230

    EDITTEXT        IDC_AI_INPUT_EDIT, 5, 260, 220, 35, ES_MULTILINE | ES_AUTOVSCROLL | WS_VSCROLL | WS_BORDER
    PUSHBUTTON      "Send", IDC_AI_SEND_BUTTON, 230, 260, 45, 35
    PUSHBUTTON      "Stop", IDC_AI_STOP_BUTTON, 230, 260, 45, 35, WS_DISABLED | WS_VISIBLE
    LTEXT           "", IDC_AI_TYPING_STATIC, 5, 298, 270, 12, SS_LEFT | SS_CENTERIMAGE | WS_DISABLED
END

IDD_AIASSISTANT_SETTINGS DIALOGEX 0, 0, 380, 410
STYLE DS_SETFONT | DS_MODALFRAME | DS_FIXEDSYS | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "AI Assistant Settings"
FONT 8, "MS Shell Dlg", 0, 0, 0x1
BEGIN
    CONTROL         "", IDC_SETTINGS_TAB_CTRL, "SysTabControl32", WS_CHILD | WS_VISIBLE | WS_CLIPSIBLINGS | TCS_TABS | WS_TABSTOP, 5, 5, 370, 365
    DEFPUSHBUTTON   "OK", IDOK, 270, 380, 45, 20
    PUSHBUTTON      "Cancel", IDCANCEL, 320, 380, 50, 20
END

IDD_TAB_PROVIDERS DIALOGEX 0, 0, 356, 330
STYLE WS_CHILD | DS_CONTROL | DS_SETFONT
FONT 8, "MS Shell Dlg", 0, 0, 0x1
BEGIN
    LTEXT           "OpenAI API Key:", IDC_OPENAI_KEY_LABEL, 10, 10, 72, 10
    EDITTEXT        IDC_OPENAI_KEY_EDIT, 88, 7, 258, 14, ES_AUTOHSCROLL | ES_PASSWORD

    LTEXT           "Gemini API Key:", IDC_GEMINI_KEY_LABEL, 10, 30, 72, 10
    EDITTEXT        IDC_GEMINI_KEY_EDIT, 88, 27, 258, 14, ES_AUTOHSCROLL | ES_PASSWORD

    LTEXT           "Claude API Key:", IDC_CLAUDE_KEY_LABEL, 10, 50, 72, 10
    EDITTEXT        IDC_CLAUDE_KEY_EDIT, 88, 47, 258, 14, ES_AUTOHSCROLL | ES_PASSWORD

    LTEXT           "Local Server URL:", IDC_LOCAL_URL_LABEL, 10, 70, 72, 10
    EDITTEXT        IDC_LOCAL_URL_EDIT, 88, 67, 258, 14, ES_AUTOHSCROLL

    LTEXT           "Local API Key (optional):", IDC_LOCAL_KEY_LABEL, 10, 90, 100, 10
    EDITTEXT        IDC_LOCAL_KEY_EDIT, 88, 87, 258, 14, ES_AUTOHSCROLL | ES_PASSWORD

    LTEXT           "Local Timeout (seconds):", IDC_LOCAL_TIMEOUT_LABEL, 10, 110, 100, 10
    EDITTEXT        IDC_LOCAL_TIMEOUT_EDIT, 88, 107, 60, 14, ES_AUTOHSCROLL | ES_NUMBER

    GROUPBOX        "Default Provider", IDC_DEFAULT_PROVIDER_GROUP, 10, 128, 336, 52
    LTEXT           "Select default AI provider:", IDC_DEFAULT_PROVIDER_LABEL, 20, 144, 110, 10
    COMBOBOX        IDC_DEFAULT_PROVIDER_COMBO, 140, 142, 120, 80, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP

    PUSHBUTTON      "Test Default Connection", IDC_TEST_CONNECTION_BTN, 10, 188, 130, 18

    GROUPBOX        "How to get API Keys", IDC_API_KEYS_GROUP, 10, 214, 336, 52
    LTEXT           "OpenAI: platform.openai.com - API Keys", IDC_API_KEYS_OPENAI_HINT, 20, 228, 310, 10
    LTEXT           "Gemini: ai.google.dev - Get API Key", IDC_API_KEYS_GEMINI_HINT, 20, 240, 310, 10
    LTEXT           "Claude: console.anthropic.com - API Keys", IDC_API_KEYS_CLAUDE_HINT, 20, 252, 310, 10
END

IDD_TAB_PROMPT DIALOGEX 0, 0, 356, 330
STYLE WS_CHILD | DS_CONTROL | DS_SETFONT
FONT 8, "MS Shell Dlg", 0, 0, 0x1
BEGIN
    LTEXT           "Preset:", IDC_PROMPT_PRESET_LABEL, 10, 8, 60, 10
    COMBOBOX        IDC_PROMPT_PRESET_COMBO, 75, 6, 140, 120, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP

    LTEXT           "Response language:", IDC_RESPONSE_LANGUAGE_LABEL, 10, 26, 90, 10
    COMBOBOX        IDC_RESPONSE_LANGUAGE_COMBO, 105, 24, 130, 80, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP

    LTEXT           "Encoding suggestion:", IDC_ENCODING_LABEL, 10, 44, 90, 10
    COMBOBOX        IDC_ENCODING_COMBO, 105, 42, 130, 100, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP

    LTEXT           "Response detail:", IDC_DETAIL_LEVEL_LABEL, 10, 62, 90, 10
    COMBOBOX        IDC_DETAIL_LEVEL_COMBO, 105, 60, 130, 80, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP

    GROUPBOX        "Scenario Modules", IDC_SCENARIO_GROUP, 10, 80, 336, 50
    AUTOCHECKBOX    "Explain code", IDC_SCENARIO_EXPLAIN_CHECK, 20, 96, 80, 12, WS_TABSTOP
    AUTOCHECKBOX    "Fix bugs", IDC_SCENARIO_FIX_CHECK, 110, 96, 70, 12, WS_TABSTOP
    AUTOCHECKBOX    "Refactor", IDC_SCENARIO_REFACTOR_CHECK, 200, 96, 70, 12, WS_TABSTOP
    AUTOCHECKBOX    "Generate tests", IDC_SCENARIO_TEST_CHECK, 20, 112, 90, 12, WS_TABSTOP
    AUTOCHECKBOX    "Write docs", IDC_SCENARIO_DOC_CHECK, 120, 112, 80, 12, WS_TABSTOP

    GROUPBOX        "Output Rules", IDC_OUTPUT_GROUP, 10, 136, 336, 36
    AUTOCHECKBOX    "Code only when suitable", IDC_OUTPUT_CODE_ONLY_CHECK, 20, 152, 110, 12, WS_TABSTOP
    AUTOCHECKBOX    "Preserve project style", IDC_OUTPUT_PRESERVE_STYLE_CHECK, 140, 152, 100, 12, WS_TABSTOP
    AUTOCHECKBOX    "Mention risks and assumptions", IDC_OUTPUT_RISKS_CHECK, 248, 152, 100, 12, WS_TABSTOP

    GROUPBOX        "Prompt Preview", IDC_CUSTOM_PROMPT_GROUP, 10, 178, 336, 142
    EDITTEXT        IDC_CUSTOM_PROMPT_EDIT, 20, 194, 316, 116, ES_MULTILINE | ES_AUTOVSCROLL | ES_READONLY | WS_VSCROLL | WS_BORDER
END

IDD_TAB_APPEARANCE DIALOGEX 0, 0, 356, 330
STYLE WS_CHILD | DS_CONTROL | DS_SETFONT
FONT 8, "MS Shell Dlg", 0, 0, 0x1
BEGIN
    LTEXT           "Language:", IDC_UI_LANGUAGE_LABEL, 20, 20, 90, 10
    COMBOBOX        IDC_UI_LANGUAGE_COMBO, 120, 18, 140, 80, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    AUTOCHECKBOX    "Require Ctrl+Enter to send from AI panel", IDC_SEND_SHORTCUT_CHECK, 20, 46, 250, 12, WS_TABSTOP
END

IDD_TAB_ABOUT DIALOGEX 0, 0, 356, 330
STYLE WS_CHILD | DS_CONTROL | DS_SETFONT
FONT 8, "MS Shell Dlg", 0, 0, 0x1
BEGIN
    LTEXT           "", IDC_ABOUT_VERSION, 20, 20, 316, 14, SS_LEFT
    LTEXT           "", IDC_ABOUT_COPYRIGHT, 20, 40, 316, 14, SS_LEFT
    LTEXT           "", IDC_ABOUT_LICENSE, 20, 60, 316, 14, SS_LEFT
    LTEXT           "", IDC_ABOUT_REPO_LINK, 20, 86, 316, 14, SS_LEFT | SS_NOTIFY
END

VS_VERSION_INFO VERSIONINFO
 FILEVERSION NPPAI_VERSION_MAJOR, NPPAI_VERSION_MINOR, NPPAI_VERSION_PATCH, NPPAI_VERSION_BUILD
 PRODUCTVERSION NPPAI_VERSION_MAJOR, NPPAI_VERSION_MINOR, NPPAI_VERSION_PATCH, NPPAI_VERSION_BUILD
 FILEFLAGSMASK 0x3fL
#ifdef _DEBUG
 FILEFLAGS 0x1L
#else
 FILEFLAGS 0x0L
#endif
 FILEOS 0x40004L
 FILETYPE 0x2L
 FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904B0"
        BEGIN
            VALUE "CompanyName", NPPAI_COMPANY_NAME
            VALUE "FileDescription", NPPAI_FILE_DESCRIPTION
            VALUE "FileVersion", NPPAI_VERSION_STRING_FULL
            VALUE "InternalName", NPPAI_PRODUCT_NAME
            VALUE "LegalCopyright", NPPAI_COPYRIGHT
            VALUE "OriginalFilename", "AI-Assistant.dll"
            VALUE "ProductName", NPPAI_PRODUCT_NAME
            VALUE "ProductVersion", NPPAI_VERSION_STRING_FULL
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 1200
    END
END
